DIGIT=(
    "$digit_0" "$digit_1" "$digit_2" "$digit_3" "$digit_4"
    "$digit_5" "$digit_6" "$digit_7" "$digit_8" "$digit_9"
)
BLOCK=$'\u2588'
for n in {0..9}; do
    digit="${DIGIT[$n]}"
    DIGIT[n]="${digit//M/$BLOCK}"
done
BANNER="${BANNER//M/$BLOCK}"
unset digit n

# KEYS:
KEY_UP=$'\e[A'
KEY_DOWN=$'\e[B'
KEY_RIGHT=$'\e[C'
KEY_LEFT=$'\e[D'

# COLORS:
BLK=$'\e[30m'; LBLK=$'\e[90m'
RED=$'\e[31m'; LRED=$'\e[91m'
GRN=$'\e[32m'; LGRN=$'\e[92m'
YEL=$'\e[33m'; LYEL=$'\e[93m'
BLU=$'\e[34m'; LBLU=$'\e[94m'
MAG=$'\e[35m'; LMAG=$'\e[95m'
CYN=$'\e[36m'; LCYN=$'\e[96m'
WHT=$'\e[37m'; LWHT=$'\e[97m'
